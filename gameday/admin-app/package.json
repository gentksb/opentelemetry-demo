{
  "name": "gameday-admin-app",
  "version": "1.0.0",
  "description": "o11y Game Day Admin Application",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "dev:all": "concurrently --names backend,frontend --prefix-colors cyan,green \"npm run dev\" \"npm --prefix frontend run dev\"",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0",
    "@hono/node-server": "^1.19.11",
    "@splunk/otel": "^3.3.0",
    "dotenv": "^16.4.0",
    "hono": "^4.12.8",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
